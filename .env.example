# PostgreSQL (общая база PlayUp). docker-compose поднимает её на 5433.
DATABASE_URL="postgresql://playup:playup@localhost:5433/playup_dev?schema=public"

# Секрет для подписи admin JWT (в проде заменить на длинную случайную строку)
JWT_SECRET="dev-secret-change-me"

# Telegram bot token для валидации init data клиентской mini app.
# В Итерации 0 можно оставить пустым и включить dev-режим ниже.
TELEGRAM_BOT_TOKEN=""

# Dev-обход проверки подписи Telegram init data (ТОЛЬКО для локальной разработки).
# Если "true" и NODE_ENV != production — backend доверяет переданному telegram_id
# без криптопроверки. В проде всегда false.
TELEGRAM_AUTH_DEV="true"
